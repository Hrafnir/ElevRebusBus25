# Leave Supabase empty for the built-in local demo mode.
# Add your own Supabase project values when testing shared backend mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Keep this true for local demo mode.
ALLOW_DEV_AUTH=true

# Optional shared app-level Google Maps key.
# Later, organizations can override this with their own restricted key.
GOOGLE_MAPS_API_KEY=
